<div class="container mt-4">
    <h2>Dispositivos</h2>
    <a href="/dashboard/device/new" class="btn btn-success mb-3">Nuevo</a>

    <!-- Búsqueda -->
    <form method="GET" action="/dashboard/device">
        <input type="text" name="search" placeholder="Buscar dispositivo..." value="<%= search %>">
        <button type="submit" class="btn-sm btn-success mt-2"><i class="fas fa-search"></i> Buscar</button>
    </form>

    <!-- Tabla de contenido a mostrar -->
    <% if (devices.length> 0) { %>
        <table class="table table-bordered table-striped text-center mt-4">
            <thead>
                <tr>
                    <th>Inventario</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>IP</th>
                    <th>Área</th>
                    <th>Responsable</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (devices.length> 0) { %>
                    <% devices.forEach(device=> { %>
                        <tr>
                            <td>
                                <%= device.inventario %>
                            </td>
                            <td>
                                <%= device.nombre %>
                            </td>
                            <td>
                                <%= device.tipo %>
                            </td>
                            <td>
                                <%= device.ip || 'Sin IP' %>
                            </td>
                            <td>
                                <%= device.area || 'Sin asignar' %>
                            </td>
                            <td>
                                <%= device.trabajador || 'Sin asignar' %>
                            </td>
                            <td>
                                <a href="/dashboard/device/<%= device.id %>" class="btn btn-sm btn-info">
                                    <i class="fas fa-search"></i><span class="tooltip">Has clic para gestionar</span>
                                </a>
                                <a href="/dashboard/device/<%= device.id %>/edit" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i><span class="tooltip">Has clic para editar</span>
                                </a>

                                <form action="/dashboard/device/<%= device.id %>/deactivate" method="POST"
                                    class="d-inline"
                                    onsubmit="confirmDeactivate(event, '<%= device.nombre %> - <%= device.inventario %>', this); return false;">
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        <i class="fa fa-archive"></i><span class="tooltip">Has clic para
                                            desactivar</span>
                                    </button>
                                </form>

                                <form action="/dashboard/device/<%= device.id %>/delete" method="POST" class="d-inline"
                                    onsubmit="confirmDelete(event, '<%= device.nombre %> - <%= device.inventario %>', this); return false;">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash-alt"></i><span class="tooltip">Has clic para
                                            eliminar</span>
                                    </button>
                                </form>

                                <a href="/dashboard/device/<%= device.id %>/incidencia"
                                    class="btn btn-sm btn-secondary">
                                    <i class="fas fa-exclamation-circle"></i><span class="tooltip">Has clic para
                                        registrar incidencia</span>
                                </a>
                                <a href="/dashboard/device/<%= device.id %>/exp_tecnico_pdf"
                                    class="btn btn-sm btn-info">
                                    <i class="fa fa-file-pdf" aria-hidden="true"></i><span class="tooltip">Has clic para
                                        imprimir expediente técnico</span>
                                </a>
                            </td>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="alert alert-warning">No se encontraron dispositivos.</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
        <% } else { %>
            </br>
            <div class="alert alert-warning">No existen datos para mostrar</div>
            <% } %>

                <!-- Paginado -->
                <nav aria-label="Page navigation">
                    <ul class="pagination">
                        <% for (let i=1; i <=Math.ceil(count / limit); i++) { %>
                            <li class="page-item <%= i == page ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %>&search=<%= search %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>
                    </ul>
                </nav>
</div>

<script>
    function confirmDeactivate(event, deviceName, formElement) {
        event.preventDefault();

        Swal.fire({
            title: '¿Desactivar dispositivo?',
            html: `
        <div style="text-align: left;">
          <p>¿Estás seguro de que deseas desactivar el dispositivo:<br>
          <strong>${deviceName}</strong>?</p>
          
          <label for="deactivationReason" style="margin-top: 15px; font-weight: bold;">
            Motivo de desactivación (opcional):
          </label>
          <textarea id="deactivationReason" 
                    class="swal2-textarea" 
                    placeholder="Ej: Dispositivo dañado, En mantenimiento, Obsoleto, etc."
                    rows="3"
                    style="resize: vertical;">
          </textarea>
          </br>
          <small class="text-muted">Este campo es opcional pero recomendado</small>
        </div>
      `,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ffc107',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, desactivar',
            cancelButtonText: 'Cancelar',
            preConfirm: () => {
                const reason = document.getElementById('deactivationReason').value;
                return { reason: reason };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                // Crear un input oculto para enviar la razón
                const reasonInput = document.createElement('input');
                reasonInput.type = 'hidden';
                reasonInput.name = 'deactivation_reason';
                reasonInput.value = result.value.reason;
                formElement.appendChild(reasonInput);
                formElement.submit();
            }
        });
    }

    function confirmDelete(event, deviceName, formElement) {
        event.preventDefault();

        Swal.fire({
            title: '¿Eliminar dispositivo?',
            html: `<strong style="color: red;">⚠️ ADVERTENCIA: Esta acción es IRREVERSIBLE ⚠️</strong><br><br>
             ¿Estás seguro de que deseas eliminar permanentemente el dispositivo:<br>
             <strong>${deviceName}</strong>?`,
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, eliminar permanentemente',
            cancelButtonText: 'Cancelar',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                formElement.submit();
            }
        });
    }
</script>